PORT=5000
MAPTILER_API_KEY=your_maptiler_api_key_here

# Phải trùng với VITE_GOOGLE_CLIENT_ID để backend xác thực Google ID token
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# Gemini API key cho chatbot AI
GEMINI_API_KEY=your_gemini_api_key_here
# Nên dùng model nhẹ/mới trước để giảm quota/cost và tránh quá tải
GEMINI_MODEL=gemini-2.5-flash-lite

# Tuỳ chọn: provider dự phòng nếu Gemini hết quota/quá tải
# Tạo miễn phí tại https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Tuỳ chọn: provider dự phòng khác nếu Gemini/Groq lỗi
# Tạo tại https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
