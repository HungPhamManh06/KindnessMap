# HERE Maps API key dùng cho Vite frontend
# Tạo key tại: https://platform.here.com/
# Vercel Environment Variable cần đặt đúng tên:
VITE_HERE_MAPS_API_KEY=your_here_maps_api_key_here

# Google OAuth Client ID dùng cho nút đăng nhập bằng Google/Gmail
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com
